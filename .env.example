# ─────────────────────────────────────────────────────────────────────────────
# Joseph's Forex Bot - Environment Variables
#
# INSTRUCTIONS:
# 1. Copy this file and rename it to .env
# 2. Fill in your actual values
# 3. NEVER commit .env to GitHub — it contains your secret keys
#
# The .gitignore file already excludes .env from being committed.
# ─────────────────────────────────────────────────────────────────────────────

# ── IG Group Broker Settings ─────────────────────────────────────────────────
# Get these from: https://www.ig.com → My IG → Settings → API
IG_API_KEY=your_ig_api_key_here
IG_USERNAME=your_ig_username_here
IG_PASSWORD=your_ig_password_here
IG_ACCOUNT_ID=your_ig_account_id_here

# Use "demo" for demo account (recommended for first month)
# Use "live" only when you're ready for real money
IG_ENVIRONMENT=demo

# ── Telegram Bot Settings ────────────────────────────────────────────────────
# Get bot token from: Telegram → @BotFather → /newbot
# Get chat ID from: https://api.telegram.org/bot<TOKEN>/getUpdates after messaging your bot
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# ── Claude AI Settings (for MCP Analysis) ───────────────────────────────────
# Get from: https://console.anthropic.com → API Keys
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ── Trading Configuration ────────────────────────────────────────────────────
# Maximum amount (in your account currency) allowed in open positions at once
MAX_CAPITAL=500

# Minimum confidence score (0-100) required before the bot places a trade
MIN_CONFIDENCE_SCORE=60

# Confidence score required to hold a position past end-of-day close
HOLD_OVERNIGHT_THRESHOLD=98

# ── GitHub ─────────────────────────────────────────────────────────────────
# Personal Access Token with repo + workflow scopes — used for deploy command
GITHUB_PAT=your_github_pat_here
# Repo in owner/name format
GITHUB_REPO=joegooderham/ai-trader-bot

# ── External Data Sources ──────────────────────────────────────────────────
# Finnhub — primary live forex candle source (free tier: 60 req/min)
# Sign up at: https://finnhub.io/register
FINNHUB_API_KEY=your_finnhub_api_key_here

# Alpha Vantage — pre-computed indicators + news sentiment (free tier: 25 calls/day)
# Sign up at: https://www.alphavantage.co/support/#api-key
ALPHA_VANTAGE_API_KEY=your_alpha_vantage_api_key_here

# Twelve Data — historical candle data for LSTM training (free tier: 800 calls/day)
# Sign up at: https://twelvedata.com/register
TWELVE_DATA_API_KEY=your_twelve_data_api_key_here

# ── Data & Storage ───────────────────────────────────────────────────────────
# Where to store local data files
DATA_DIR=/app/data_store

# GitHub repo URL (for reference/documentation purposes)
GITHUB_REPO_URL=https://github.com/yourusername/josephs-forex-bot

# ── Notification Preferences ────────────────────────────────────────────────
# Set to true/false to control what notifications you receive
NOTIFY_ON_TRADE_OPEN=true
NOTIFY_ON_TRADE_CLOSE=true
NOTIFY_ON_DAILY_REPORT=true
NOTIFY_ON_WEEKLY_REPORT=true
NOTIFY_ON_HEALTH_ALERT=true
NOTIFY_ON_OVERNIGHT_HOLD=true
