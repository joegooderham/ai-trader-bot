# ─────────────────────────────────────────────────────────────────────────────
# Joseph's Forex Bot - Environment Variables
#
# INSTRUCTIONS:
# 1. Copy this file and rename it to .env
# 2. Fill in your actual values
# 3. NEVER commit .env to GitHub — it contains your secret keys
#
# The .gitignore file already excludes .env from being committed.
# ─────────────────────────────────────────────────────────────────────────────

# ── OANDA Broker Settings ────────────────────────────────────────────────────
# Get these from: https://www.oanda.com → My Account → API Access
OANDA_API_TOKEN=your_oanda_api_token_here
OANDA_ACCOUNT_ID=your_oanda_account_id_here

# Use "practice" for demo account (recommended for first month)
# Use "live" only when you're ready for real money
OANDA_ENVIRONMENT=practice

# ── Telegram Bot Settings ────────────────────────────────────────────────────
# Get bot token from: Telegram → @BotFather → /newbot
# Get chat ID from: https://api.telegram.org/bot<TOKEN>/getUpdates after messaging your bot
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# ── Claude AI Settings (for MCP Analysis) ───────────────────────────────────
# Get from: https://console.anthropic.com → API Keys
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ── Trading Configuration ────────────────────────────────────────────────────
# Maximum amount (in your account currency) allowed in open positions at once
MAX_CAPITAL=500

# Minimum confidence score (0-100) required before the bot places a trade
MIN_CONFIDENCE_SCORE=60

# Confidence score required to hold a position past end-of-day close
HOLD_OVERNIGHT_THRESHOLD=98

# ── Data & Storage ───────────────────────────────────────────────────────────
# Where to store local data files
DATA_DIR=/app/data

# GitHub repo URL (for reference/documentation purposes)
GITHUB_REPO_URL=https://github.com/yourusername/josephs-forex-bot

# ── Notification Preferences ────────────────────────────────────────────────
# Set to true/false to control what notifications you receive
NOTIFY_ON_TRADE_OPEN=true
NOTIFY_ON_TRADE_CLOSE=true
NOTIFY_ON_DAILY_REPORT=true
NOTIFY_ON_WEEKLY_REPORT=true
NOTIFY_ON_HEALTH_ALERT=true
NOTIFY_ON_OVERNIGHT_HOLD=true
