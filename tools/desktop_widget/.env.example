# AI Trader Bot — Desktop Widget Configuration
#
# Copy this file to .env and fill in your values.

# Bot command API URL (dashboard proxy)
# Default: http://localhost:8050/api/cmd
# If using Cloudflare tunnel: https://aitradefintech.com/api/cmd
BOT_URL=http://localhost:8050/api/cmd

# Auth token (same as DASHBOARD_CMD_TOKEN in docker-compose)
# Leave blank if no token is set (dev mode)
DASHBOARD_CMD_TOKEN=

# How often to refresh positions (seconds, minimum 5)
REFRESH_INTERVAL=30
